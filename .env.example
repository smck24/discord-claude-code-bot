# Copy this file to .env and fill in the values. Never commit the real .env.

# Bot tab -> Reset Token in the Discord Developer Portal
DISCORD_BOT_TOKEN=

# Right-click your server icon (with Developer Mode on) -> Copy Server ID
DISCORD_GUILD_ID=

# Right-click the #claude / #ai-chat channel -> Copy Channel ID
CLAUDE_CHANNEL_ID=

# console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# auto (recommended) | acceptEdits | plan | dontAsk | bypassPermissions
# See the README before changing this away from "auto".
CLAUDE_PERMISSION_MODE=auto

# How long a single /code invocation is allowed to run before being killed
CLAUDE_TIMEOUT_SECONDS=300

# Simple per-instance rate limit
MAX_INVOCATIONS_PER_HOUR=20
